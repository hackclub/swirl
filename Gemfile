source "https://rubygems.org"

# The site is built with Jekyll 4 via GitHub Actions (see
# .github/workflows/pages.yml), so it runs on current Ruby versions.
# Run `bundle install`, then `bundle exec jekyll serve` to preview locally.
gem "jekyll", "~> 4.4"

# Standard-library gems that Ruby 3.4+ no longer bundles by default.
# Harmless on older Rubies; keep Jekyll happy on newer ones.
gem "csv"
gem "base64"
gem "bigdecimal"
gem "logger"
gem "webrick"
